@page
@using portfolio.Models
@namespace portfolio.Pages
@model ContactModel
@{
    ViewData["Title"] = "Contact - Jomell Alba";
}

<!-- Page Header -->
<section class="page-header bg-light py-5">
    <div class="container-lg text-center">
        <h1 class="display-4 fw-bold mb-2">Get In Touch</h1>
        <p class="lead text-muted">I'd love to hear from you</p>
    </div>
</section>

<!-- Contact Section -->
<section class="contact-section py-5">
    <div class="container-lg">
        <div class="row g-5">
            <!-- Contact Form -->
            <div class="col-lg-8">
                <div class="contact-form-wrapper">
                    <h2 class="display-6 fw-bold mb-4">Send Me a Message</h2>

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            <strong>Success!</strong> @Model.SuccessMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <strong>Error!</strong> @Model.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form method="post" class="needs-validation">
                        <div class="mb-3">
                            <label for="name" class="form-label fw-bold">Full Name</label>
                            <input type="text" class="form-control form-control-lg" id="name" name="name" 
                                   placeholder="Your name" required value="@Model.Contact?.Name">
                            <small class="text-muted">Required</small>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-bold">Email Address</label>
                            <input type="email" class="form-control form-control-lg" id="email" name="email" 
                                   placeholder="your.email@example.com" required value="@Model.Contact?.Email">
                            <small class="text-muted">Required</small>
                        </div>

                        <div class="mb-3">
                            <label for="subject" class="form-label fw-bold">Subject</label>
                            <input type="text" class="form-control form-control-lg" id="subject" name="subject" 
                                   placeholder="What's this about?" required value="@Model.Contact?.Subject">
                            <small class="text-muted">Required</small>
                        </div>

                        <div class="mb-3">
                            <label for="message" class="form-label fw-bold">Message</label>
                            <textarea class="form-control" id="message" name="message" rows="6" 
                                      placeholder="Tell me more about your project or inquiry..." required>@Model.Contact?.Message</textarea>
                            <small class="text-muted">Required</small>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-paper-plane me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="col-lg-4">
                <div class="contact-info">
                    <h2 class="display-6 fw-bold mb-4">Contact Info</h2>

                    <div class="contact-item mb-5">
                        <h5 class="fw-bold text-primary mb-3">
                            <i class="fas fa-envelope fa-lg me-3"></i>Email
                        </h5>
                        <a href="mailto:albajomell@gmail.com" class="text-decoration-none text-muted">
                            albajomell@gmail.com
                        </a>
                    </div>

                    <div class="contact-item mb-5">
                        <h5 class="fw-bold text-primary mb-3">
                            <i class="fas fa-map-marker-alt fa-lg me-3"></i>Location
                        </h5>
                        <p class="text-muted">
                            Manila, Philippines
                        </p>
                    </div>

                    <div class="contact-item mb-5">
                        <h5 class="fw-bold text-primary mb-3">
                            <i class="fas fa-link fa-lg me-3"></i>Social Links
                        </h5>
                        <div class="social-links-contact">
                            <a href="https://github.com/Jomzie" target="_blank" class="btn btn-outline-primary btn-sm me-2 mb-2">
                                <i class="fab fa-github me-1"></i>GitHub
                            </a>
                            <a href="https://www.linkedin.com/in/jomell-alba-1290a025a/" target="_blank" class="btn btn-outline-primary btn-sm me-2 mb-2">
                                <i class="fab fa-linkedin me-1"></i>LinkedIn
                            </a>
                        </div>
                    </div>

                    <div class="contact-item">
                        <h5 class="fw-bold text-primary mb-3">
                            <i class="fas fa-clock fa-lg me-3"></i>Response Time
                        </h5>
                        <p class="text-muted">
                            I typically respond within 24-48 hours. Let's connect!
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section (Optional) -->
<section class="faq-section py-5 bg-light">
    <div class="container-lg">
        <h2 class="display-6 fw-bold mb-5 text-center">Frequently Asked Questions</h2>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="accordion" id="faqAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                What services do you offer?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                I offer full-stack web development, machine learning solutions, data analysis, 
                                cloud deployment, and consulting services. Feel free to reach out to discuss your specific needs!
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                What's your availability?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                I'm currently available for freelance projects and collaborations. 
                                Contact me to discuss timelines and project requirements.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                How long does a typical project take?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Project duration varies depending on scope and complexity. 
                                Simple projects may take weeks, while larger initiatives can span months. 
                                I'll provide a detailed timeline after understanding your requirements.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Do you work with startups?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                Absolutely! I love working with startups and early-stage companies. 
                                I understand the unique challenges and can provide scalable, cost-effective solutions.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
