                <div class="project-card-full">
                    <div class="project-card-header">
                        <i class="fas fa-cogs fa-4x text-primary"></i>
                    </div>
                    <h5 class="fw-bold mt-3 mb-2">API Development</h5>
                    <p class="text-muted text-sm mb-3">
                        RESTful and GraphQL APIs with robust error handling, validation, and comprehensive documentation.
                    </p>
                    <div class="tech-stack mb-3">
                        <span class="badge bg-secondary-light">ASP.NET Core</span>
                        <span class="badge bg-secondary-light">Node.js</span>
                        <span class="badge bg-secondary-light">REST</span>
                        <span class="badge bg-secondary-light">GraphQL</span>
                    </div>
                    <a href="#" class="btn btn-sm btn-outline-primary">
