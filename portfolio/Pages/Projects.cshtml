                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section bg-primary text-white py-5">
    <div class="container-lg text-center">
        <h2 class="display-6 fw-bold mb-4">Interested in a Project?</h2>
        <p class="lead mb-4">
            Let's discuss how I can help bring your ideas to reality.
        </p>
        <a href="/contact" class="btn btn-light btn-lg">
            Start a Conversation <i class="fas fa-envelope ms-2"></i>
        </a>
    </div>
</section>
