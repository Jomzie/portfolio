@page
@namespace portfolio.Pages
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<!-- Error Section -->
<section class="error-section d-flex align-items-center justify-content-center min-vh-100">
    <div class="container-lg text-center">
        <div class="error-content">
            <h1 class="display-1 fw-bold text-primary mb-4">404</h1>
            <h2 class="display-6 fw-bold mb-3">Page Not Found</h2>
            <p class="lead text-muted mb-5">
                Sorry, the page you're looking for doesn't exist. It might have been moved or deleted.
            </p>
            <a href="/" class="btn btn-primary btn-lg me-3">
                <i class="fas fa-home me-2"></i>Go Home
            </a>
            <a href="/projects" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-briefcase me-2"></i>View Projects
            </a>
        </div>
    </div>
</section>
